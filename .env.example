# ---- Model gateway (local-first) ----
# Default provider for debaters/party. One of: ollama | anthropic | openai | groq | cerebras | gemini | openrouter
LLM_PROVIDER=ollama
# Model aliases resolve in app/gateway/models.py. Bottom-up: start local.
# llama3.2:3b is the default everywhere — one warm, fast, non-"thinking" model so
# the single-slot CPU Ollama never swaps mid-round. Pull it: `ollama pull llama3.2:3b`.
LLM_DEFAULT_MODEL=llama3.2:3b
LLM_JUDGE_MODEL=llama3.2:3b
LLM_EMBED_MODEL=nomic-embed-text
GATEWAY_FALLBACK_ENABLED=true
GATEWAY_ACTOR_CANDIDATES=groq/llama-3.1-8b-instant,cerebras/llama-3.3-70b,gemini/gemini-2.5-flash-lite,openrouter/openrouter/free,ollama/llama3.2:3b
GATEWAY_JUDGE_CANDIDATES=groq/llama-3.3-70b-versatile,cerebras/llama-3.3-70b,gemini/gemini-2.5-flash,ollama/llama3.2:3b

# ---- Battle model + latency budget (local-first, real LLM responses) ----
# One fast model for actors AND judge so the single Ollama slot never swaps.
ACTOR_MODEL=llama3.2:3b
JUDGE_MODEL_FAST=llama3.2:3b
# Give the local model real room to respond before any templated fallback.
FIRST_TOKEN_TIMEOUT_S=45
FIRST_TOKEN_TIMEOUT_WARM_S=60
LLM_CALL_TIMEOUT_S=60
# Keep the model resident across turn-to-turn idle gaps.
OLLAMA_KEEP_ALIVE=30m

# Ollama (local). Inside docker compose the host is the service name.
OLLAMA_BASE_URL=http://ollama:11434

# Cloud providers (optional — only needed if you switch a model's provider)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Datastores ----
POSTGRES_USER=debate
POSTGRES_PASSWORD=debate
POSTGRES_DB=debate
# Inside compose the host is the service name `postgres`.
DATABASE_URL=postgresql+asyncpg://debate:debate@postgres:5432/debate
REDIS_URL=redis://redis:6379/0

# RedisVL memory hot-cache (vector ANN in front of pgvector). Needs Redis 8+.
# Set MEMORY_CACHE_ENABLED=false to fall back to pure pgvector retrieval.
MEMORY_CACHE_ENABLED=true
REDIS_INDEX_NAME=mem_idx

# ---- App ----
API_PORT=8000
WEB_PORT=5173
# Comma-separated CORS origins for the web app.
CORS_ORIGINS=http://localhost:5173
